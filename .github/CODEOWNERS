# Retrieval pipeline — ranking, fusion, quality regressions are silent
src/archivist/retrieval/                    @NetworkBuild3r

# Write pipeline — affects all stored memories
src/archivist/write/                        @NetworkBuild3r

# Core config + shared utilities — changes affect the whole system
src/archivist/core/                         @NetworkBuild3r
src/archivist/utils/                        @NetworkBuild3r

# CI/CD — pipeline changes require owner review
.github/                                    @NetworkBuild3r

# Dependency files — security-sensitive
