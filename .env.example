# ── Archivist Configuration ──────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# **Never commit `.env`** — it is listed in `.gitignore` (secrets, Tailscale keys, API keys).
#
# Docker Compose (`docker compose up`):
#   - The compose file sets QDRANT_URL=http://qdrant:6333 inside the archivist container.
#   - Point EMBED_URL at host services with host.docker.internal, e.g. vLLM on :8000:
#       EMBED_URL=http://host.docker.internal:8000
#   - Cloud LLM (xAI): LLM_URL=https://api.x.ai  (no /v1 suffix — the app adds /v1/chat/completions)
#   - Linux: compose adds host.docker.internal via host-gateway so the above works.
#
# Host-only (python -m / pytest / benchmarks on bare metal):
#   - QDRANT_URL=http://127.0.0.1:6333

# LLM API (any OpenAI-compatible endpoint)
LLM_URL=http://localhost:4000
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your-api-key-here

# Embedding API (any OpenAI-compatible /v1/embeddings endpoint)
EMBED_URL=http://localhost:4000
EMBED_MODEL=text-embedding-v3
VECTOR_DIM=1024

# ── vLLM (host benchmarks / bare metal) ─────────────────────────────────────
# vLLM exposes OpenAI-compatible /v1/chat/completions and often /v1/embeddings.
# Point both URLs at the same server if one process serves chat + embed, or split ports.
#
# Example: chat + embeddings on one vLLM (port 8000), empty API key for local:
#   LLM_URL=http://127.0.0.1:8000
#   LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#   LLM_API_KEY=
#   EMBED_URL=http://127.0.0.1:8000
#   EMBED_MODEL=BAAI/bge-base-en-v1.5
#   VECTOR_DIM=768
#
# Second vLLM only for embeddings (port 8001):
#   EMBED_URL=http://127.0.0.1:8001
#
# Academic benchmarks (`bash benchmarks/scripts/run_academic_benchmarks.sh`) load `.env`
# from the repo root automatically; ensure this file is copied to `.env` and filled in.

# Qdrant vector store (host runs only; omit or ignore when using docker compose for archivist)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=archivist_memories

# Storage paths
MEMORY_ROOT=/data/memories
SQLITE_PATH=/data/archivist/graph.db
NAMESPACES_CONFIG_PATH=/data/archivist/config/namespaces.yaml

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100
PARENT_CHUNK_SIZE=2000
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=500
CHILD_CHUNK_OVERLAP=100

# Retrieval
RETRIEVAL_THRESHOLD=0.65
VECTOR_SEARCH_LIMIT=64
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_K=10

# Tiered context (v0.5) — auto-generates L0/L1 summaries on ingest
# TIERED_CONTEXT_ENABLED=true
# L0_MAX_TOKENS=100
# L1_MAX_TOKENS=500

# Graph-augmented retrieval (v0.5)
# GRAPH_RETRIEVAL_ENABLED=true
# GRAPH_RETRIEVAL_WEIGHT=0.3
# MULTI_HOP_DEPTH=2
# TEMPORAL_DECAY_HALFLIFE_DAYS=30

# Trajectory & outcome-aware retrieval (v0.6)
# OUTCOME_RETRIEVAL_BOOST=0.15
# OUTCOME_RETRIEVAL_PENALTY=0.1

# Skill health scoring window (v0.7) — number of days of event history for health aggregation
# (No env vars needed — skill registry is automatic. memory_type on archivist_store is optional.)

# Hot cache (v0.8) — per-agent LRU cache between session and long-term store
# HOT_CACHE_ENABLED=true
# HOT_CACHE_MAX_PER_AGENT=128
# HOT_CACHE_TTL_SECONDS=600

# Consistency baseline (v0.8) — eventual, session, or strong
# DEFAULT_CONSISTENCY=eventual

# Retrieval trajectory export (v0.8)
# TRAJECTORY_EXPORT_ENABLED=true
# TRAJECTORY_EXPORT_MAX=200

# Webhooks (v0.9) — fire HTTP POSTs on memory/conflict/skill events
# WEBHOOK_URL=https://your-webhook-endpoint.example.com/archivist
# WEBHOOK_TIMEOUT=5
# WEBHOOK_EVENTS=memory_store,memory_conflict,skill_event

# Prometheus metrics (v0.9) — GET /metrics
# METRICS_ENABLED=true

# Curator
CURATOR_INTERVAL_MINUTES=30
CURATOR_EXTRACT_PREFIXES=agents/,memories/
CURATOR_EXTRACT_SKIP_SEGMENTS=skills,.cursor,.git

# Server
MCP_PORT=3100

# Optional: require Authorization: Bearer <key> or X-API-Key on all routes except GET /health
# ARCHIVIST_API_KEY=

# Pre-store conflict check (vector similarity vs other agents in same namespace)
# CONFLICT_CHECK_ON_STORE=true
# CONFLICT_BLOCK_ON_STORE=true

# Agent team mapping (optional — path to YAML file or inline JSON)
# TEAM_MAP_PATH=/data/archivist/config/team_map.yaml
# TEAM_MAP_JSON={"alice":"research","bob":"infra"}

# Docker compose: local memory directory to mount
MEMORY_DIR=./sample-memories

# ── Curator Intelligence (v1.0) ─────────────────────────────────────────────
# LLM-adjudicated dedup on store (triggers above similarity threshold)
# DEDUP_LLM_ENABLED=true
# DEDUP_LLM_THRESHOLD=0.80

# Tip consolidation budget (max LLM calls per curator cycle)
# CURATOR_TIP_BUDGET=20

# Curator queue drain interval (seconds)
# CURATOR_QUEUE_DRAIN_INTERVAL=30

# Hotness scoring weight and halflife
# HOTNESS_WEIGHT=0.15
# HOTNESS_HALFLIFE_DAYS=7
